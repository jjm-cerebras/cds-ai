{
  "colors": {
    "accent": { "$type": "color", "$value": "oklch(66.1% 0.196 37.71)" },
    "accent-hover": { "$type": "color", "$value": "oklch(77.6% 0.145 49.61)" },
    "accent-subtle": { "$type": "color", "$value": "oklch(98% 0.01 17)" },
    "accent-hover-subtle": { "$type": "color", "$value": "oklch(98.5% 0.006 51)" },
    "surface": { "$type": "color", "$value": "oklch(97.1% 0.005 78.3)" },
    "foreground": { "$type": "color", "$value": "oklch(0.2156 0 0)" },
    "foreground-muted": { "$type": "color", "$value": "oklch(0.5 0.003 67.78)" },
    "divider": { "$type": "color", "$value": "oklch(0.9331 0.0067 67.74)" }
  },
  "typography": {
    "page-title": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "1.25rem", "fontWeight": 500, "lineHeight": 1.25, "letterSpacing": "-0.02em" }
    },
    "section-title": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "1rem", "fontWeight": 500, "lineHeight": 1.3, "letterSpacing": "-0.02em" }
    },
    "body": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.875rem", "fontWeight": 400, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    },
    "body-medium": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.875rem", "fontWeight": 500, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    },
    "bold-text": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.875rem", "fontWeight": 600, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    },
    "input": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.875rem", "fontWeight": 500, "lineHeight": 1.5, "letterSpacing": "-0.01em" }
    },
    "button": {
      "$type": "typography",
      "$value": { "fontFamily": "Sometype Mono", "fontSize": "0.875rem", "fontWeight": 600, "lineHeight": 1, "letterSpacing": "0.01em", "textTransform": "uppercase" }
    },
    "small-text": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.8125rem", "fontWeight": 500, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    },
    "helper-text": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.75rem", "fontWeight": 400, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    },
    "table-header": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "0.75rem", "fontWeight": 600, "lineHeight": 1, "letterSpacing": "0.02em" }
    },
    "code": {
      "$type": "typography",
      "$value": { "fontFamily": "Sometype Mono", "fontSize": "0.875rem", "fontWeight": 500, "lineHeight": 1.4, "letterSpacing": "-0.01em" }
    }
  }
}
