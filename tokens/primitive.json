  "spacing": {
    "0": { "$type": "dimension", "$value": "0rem" },
    "0.5": { "$type": "dimension", "$value": "0.125rem" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.25rem" },
    "6": { "$type": "dimension", "$value": "1.5rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "10": { "$type": "dimension", "$value": "2.5rem" },
    "12": { "$type": "dimension", "$value": "3rem" }
  },
  "rounded": {
    "sm": { "$type": "dimension", "$value": "0.125rem" },
    "md": { "$type": "dimension", "$value": "0.25rem" },
    "lg": { "$type": "dimension", "$value": "0.5rem" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "borders": {
    "width-default": { "$type": "dimension", "$value": "1px" },
    "width-medium": { "$type": "dimension", "$value": "1.5px" },
    "width-thick": { "$type": "dimension", "$value": "2px" },
    "color-default": { "$type": "color", "$value": "{colors.divider}" },
    "focus-ring": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "4px", "color": "#89D8F0" }
    }
  },
  "shadows": {
    "default": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "4px", "spread": "0px", "color": "#0000000F" }
    },
    "md": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "1px", "color": "#0000000F" }
    },
    "lg": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "3px", "blur": "8px", "spread": "2px", "color": "#0000000F" }
    },
    "soft-lg": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "3px", "blur": "8px", "spread": "2px", "color": "#2222222F" }
    },
    "error": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "8px", "spread": "-4px", "color": "#0000000F" },
        { "offsetX": "1px", "offsetY": "4px", "blur": "20px", "spread": "-4px", "color": "#0000001A" }
      ]
    },
    "focus": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "4px", "color": "#89D8F0" }
    },
    "overlay": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "8px", "blur": "24px", "spread": "0", "color": "rgba(0, 0, 0, 0.08)" }
    }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "150ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slide": { "$type": "duration", "$value": "400ms" },
      "spinner": { "$type": "duration", "$value": "0.7s" }
    },
    "easing": {
      "standard": { "$value": "ease" },
      "slide": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)" }
    },
    "named": {
      "fadeSlide": { "$value": "fade + 4px rise, 150ms ease (dropdowns/popovers)" },
      "contentShow": { "$value": "fade + var(--modal-rise, 8px) rise, 200ms ease (modals)" },
      "overlayShow": { "$value": "fade in, 150ms ease (modal blanket)" },
      "reducedMotion": { "$value": "--modal-rise collapses to 0px under prefers-reduced-motion; motion becomes opacity-only" }
    }
  },
  "typography": {
    "family-sans": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope" }
    },
    "family-mono": {
      "$type": "typography",
      "$value": { "fontFamily": "Sometype Mono" }
    },
    "weight-light": {
      "$type": "typography",
      "$value": { "fontWeight": 300 }
    },
    "weight-regular": {
      "$type": "typography",
      "$value": { "fontWeight": 400 }
    },
    "weight-medium": {
      "$type": "typography",
      "$value": { "fontWeight": 500 }
    },
    "weight-semibold": {
      "$type": "typography",
      "$value": { "fontWeight": 600 }
    },
    "weight-bold": {
      "$type": "typography",
      "$value": { "fontWeight": 700 }
    },
    "display-xl": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "6rem", "fontWeight": 700, "lineHeight": 1.3 }
    },
    "display-large": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "3rem", "fontWeight": 700, "lineHeight": "3.5rem" }
    },
    "display-medium": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "2rem", "fontWeight": 700, "lineHeight": "2.375rem" }
    },
    "display-small": {
      "$type": "typography",
      "$value": { "fontFamily": "Manrope", "fontSize": "1.625rem", "fontWeight": 700, "lineHeight": "1.875rem" }
    }
  }
}
